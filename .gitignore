# Secrets — never commit
.voxtral.env
*.env
!*.env.example

# Per-pod runtime state (regenerated on every deploy)
runpod-pod-info.json

# Personal/local notes — anything ending in `.local.<ext>` stays out of git
# (e.g. keys.local.md, scratch.local.txt, debug.local.json,
#       qwen_voices_manifest.local.json with brand transcripts)
*.local.*

# Personal one-off generators (contain brand/marketing copy, not generic recipe)
generate-murmure-*.py

# Generated audio (voices are CC BY-NC, do not redistribute)
test_audio/
samples/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Python
__pycache__/
*.pyc
.venv/
