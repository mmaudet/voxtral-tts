# Copy to `.voxtral.env` (chmod 600) and fill in your tokens.
# `.voxtral.env` is git-ignored.

# RunPod API key — Settings → API Keys → "Create API Key" with "Read+Write" scope
# https://www.runpod.io/console/user/settings
export RUNPOD_API_KEY=

# HuggingFace user access token — Settings → Access Tokens → "New token" (read scope is enough)
# https://huggingface.co/settings/tokens
# The Voxtral-4B-TTS-2603 repo is NOT gated, but the token still helps with rate limits.
export HF_TOKEN=

# (Optional) Public SSH key for a colleague's secondary pod (`voxtral-colleague`).
# Multiple keys can be concatenated (one per line) when creating the pod.
# export COLLEAGUE_SSH_PUBKEY="ssh-ed25519 AAAA... colleague@host"
