# Copy to `.voxtral.env` (chmod 600) and fill in your tokens.
# `.voxtral.env` is git-ignored.

# RunPod API key — Settings → API Keys → "Create API Key" with "Read+Write" scope
# https://www.runpod.io/console/user/settings
export RUNPOD_API_KEY=

# HuggingFace user access token — Settings → Access Tokens → "New token" (read scope is enough)
# https://huggingface.co/settings/tokens
# The Voxtral-4B-TTS-2603 repo is NOT gated, but the token still helps with rate limits.
export HF_TOKEN=

# (Optional) Public SSH key for a colleague's secondary pod (`voxtral-colleague`).
# Multiple keys can be concatenated (one per line) when creating the pod.
# export COLLEAGUE_SSH_PUBKEY="ssh-ed25519 AAAA... colleague@host"

# ── LiteLLM virtual keys ─────────────────────────────────────────────────────
# `restart-pod.sh` (and `start_services.sh` on the pod) read these and write
# them into /workspace/.litellm.env on the pod. LiteLLM's custom_auth (auth.py)
# then accepts any of them on /v1/audio/speech. None of them ever touches the
# git-tracked YAML.
#
# Generate fresh values with:
#   python3 -c 'import secrets; print(f"sk-voxtral-owner-{secrets.token_urlsafe(24)}")'
# Pick a stable prefix per consumer so logs (LiteLLM tags requests by user_id
# derived from the env-var name suffix, lowercased) stay readable.

export VOXTRAL_KEY_OWNER=
export VOXTRAL_KEY_COLLEAGUE=

# Master key — admin-only (LiteLLM /key/* and /metrics). Never share this.
# With custom_auth enabled, master_key does NOT grant access to /v1/audio/speech;
# inference is gated by the per-user keys above.
export VOXTRAL_LITELLM_MASTER_KEY=
